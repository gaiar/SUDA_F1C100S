[submodule "kernel/linux"]
	path = kernel/linux
	url = https://github.com/Lichee-Pi/linux.git
	branch = nano-4.14-exp
[submodule "tools/crosstool-ng"]
	path = tools/crosstool-ng
	url = https://github.com/crosstool-ng/crosstool-ng.git
	branch = master
[submodule "rootfs/buildroot"]
	path = rootfs/buildroot
	url = https://github.com/buildroot/buildroot.git
	branch = master
[submodule "tools/sunxi-tools"]
	path = tools/sunxi-tools
	url = https://github.com/Icenowy/sunxi-tools.git
	branch = f1c100s-spiflash
[submodule "bootloader/u-boot"]
	path = bootloader/u-boot
	url = https://github.com/Lichee-Pi/u-boot.git
	branch = nano-v2018.01
